<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Dashboard Admin - Luapin Aja</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com"></script>
<style>
    body { font-family: 'Manrope', sans-serif; background: #f0f2f5; }
    .glass-nav { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,0,0,0.05); }
    .social-card { background: #ffffff; border-radius: 12px; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1); border: 1px solid rgba(0,0,0,0.05); }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
    .icon-fill { font-variation-settings: 'FILL' 1; }
</style>
</head>
<body class="text-slate-800 flex flex-col min-h-screen">

<nav class="fixed top-0 w-full z-50 glass-nav">
<div class="max-w-[800px] mx-auto flex justify-between items-center h-14 px-4">
    <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-indigo-600 icon-fill text-[24px]">shield_person</span>
        <span class="text-lg font-bold tracking-tighter">Admin Panel</span>
    </div>
    <a href="/logout" class="text-xs font-extrabold text-rose-500 bg-rose-50 px-4 py-2 rounded-full hover:bg-rose-100 transition-colors">Keluar</a>
</div>
</nav>

<main class="max-w-[800px] w-full mx-auto px-4 pt-20 pb-20 flex-grow">
    <section class="grid grid-cols-3 gap-3 mb-8">
        <div class="social-card p-4 text-center">
            <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-wider mb-1">Total</p>
            <p class="text-xl font-extrabold text-indigo-600"><%= stats.total %></p>
        </div>
        <div class="social-card p-4 text-center border-b-4 border-b-amber-400">
            <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-wider mb-1">Antrean</p>
            <p class="text-xl font-extrabold text-amber-500"><%= stats.pending %></p>
        </div>
        <div class="social-card p-4 text-center border-b-4 border-b-emerald-400">
            <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-wider mb-1">Live</p>
            <p class="text-xl font-extrabold text-emerald-500"><%= stats.approved %></p>
        </div>
    </section>

    <div class="space-y-4">
        <% confessions.forEach(function(item) { %>
            <div class="social-card overflow-hidden">
                <div class="p-4 flex items-center justify-between border-b border-slate-50">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 <%= item.status === 'pending' ? 'bg-amber-100 text-amber-600' : 'bg-indigo-100 text-indigo-600' %> rounded-full flex items-center justify-center font-bold text-sm">
                            <%= (item.pengirim || 'A').charAt(0).toUpperCase() %>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-slate-900"><%= item.pengirim || 'Anonim' %></h3>
                            <p class="text-[11px] text-slate-500 font-medium"><%= item.waktuFormat %></p>
                        </div>
                    </div>
                    <div class="flex gap-1">
                        <% if (item.status === 'pending') { %>
                            <form action="/dashboard/approve/<%= item.id %>" method="POST">
                                <button type="submit" class="p-2 text-emerald-500 hover:bg-emerald-50 rounded-full transition-colors" title="Setujui">
                                    <span class="material-symbols-outlined icon-fill">check_circle</span>
                                </button>
                            </form>
                        <% } %>
                        <form action="/dashboard/delete/<%= item.id %>" method="POST">
                            <button type="submit" class="p-2 text-rose-500 hover:bg-rose-50 rounded-full transition-colors" title="Hapus">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </form>
                    </div>
                </div>

                <div class="p-4 bg-white">
                    <% if (item.category && item.category !== 'Tanpa Kategori') { %>
                        <span class="text-[10px] font-bold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded mb-2 inline-block">#<%= item.category %></span>
                    <% } %>
                    <p class="text-[15px] text-slate-800 leading-relaxed font-medium"><%= item.message %></p>
                </div>

                <% if (item.komentar && item.komentar.length > 0) { %>
                    <div class="px-4 pb-4">
                        <div class="bg-slate-50 rounded-xl p-3 space-y-3">
                            <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-tighter"><%= item.komentar.length %> Komentar</p>
                            <% item.komentar.forEach(function(komen) { %>
                                <div class="flex justify-between items-start gap-2 bg-white p-2.5 rounded-lg border border-slate-100 shadow-sm">
                                    <div class="flex-grow">
                                        <p class="text-xs font-bold text-indigo-600 mb-0.5"><%= komen.pengirim %></p>
                                        <p class="text-sm text-slate-700 leading-snug"><%= komen.teks %></p>
                                    </div>
                                    <form action="/dashboard/delete-komen/<%= item.id %>/<%= komen.id %>" method="POST">
                                        <button type="submit" class="p-1 text-slate-300 hover:text-rose-500 transition-colors">
                                            <span class="material-symbols-outlined text-[18px]">close</span>
                                        </button>
                                    </form>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                <% } %>
            </div>
        <% }); %>
    </div>
</main>

<footer class="w-full text-center py-8 text-slate-400 mt-auto">
    <p class="text-[11px] font-bold tracking-widest uppercase">Copyright &copy; 2026 AP. All rights reserved.</p>
</footer>
</body>
</html>
