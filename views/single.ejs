<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Luapin Aja</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com"></script>
<style>
    body { font-family: 'Manrope', sans-serif; background: #f0f2f5; }
    .glass-nav { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,0,0,0.05); }
    .social-card { background: #ffffff; border-radius: 12px; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1); border: 1px solid rgba(0,0,0,0.05); }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
    .icon-fill { font-variation-settings: 'FILL' 1; }
</style>
</head>
<body class="text-slate-800 flex flex-col min-h-screen" oncontextmenu="return false;">

<nav class="fixed top-0 w-full z-40 glass-nav">
    <div class="max-w-[680px] mx-auto flex justify-between items-center h-14 px-4">
        <div class="flex items-center gap-3">
            <a href="/jelajah" class="p-2 hover:bg-slate-100 rounded-full transition-colors">
                <span class="material-symbols-outlined text-slate-600">arrow_back</span>
            </a>
            <a href="/" class="flex items-center gap-2 group">
                <span class="material-symbols-outlined text-indigo-600 icon-fill text-[28px]">psychology_alt</span>
                <span class="text-lg font-bold tracking-tighter">Luapin Aja</span>
            </a>
        </div>
    </div>
</nav>

<main class="max-w-[680px] w-full mx-auto px-4 pt-20 pb-20 flex-grow">
    <div class="social-card mb-6">
        <div class="p-4 flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center font-bold text-sm">
                <%= (confession.pengirim || 'A').charAt(0).toUpperCase() %>
            </div>
            <div>
                <h3 class="text-sm font-bold text-slate-900"><%= confession.pengirim || 'Anonim' %></h3>
                <p class="text-[11px] text-slate-500 font-medium"><%= confession.waktuFormat %></p>
            </div>
        </div>

        <div class="px-4 pb-6">
            <% if (confession.category && confession.category !== 'Tanpa Kategori') { %>
                <span class="text-[11px] font-bold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-md mb-3 inline-block">
                    #<%= confession.category %>
                </span>
            <% } %>
            <p class="text-[17px] font-semibold text-slate-800 leading-relaxed"><%= confession.message %></p>
        </div>

        <div class="px-4 py-3 border-t border-slate-50 flex items-center justify-between">
            <div class="flex items-center gap-1.5">
                <div class="bg-rose-500 text-white rounded-full p-0.5 flex"><span class="material-symbols-outlined text-[10px] icon-fill">favorite</span></div>
                <span class="text-xs text-slate-500 font-bold"><%= confession.hugs || 0 %> Dukungan</span>
            </div>
            <button onclick="salinLink('<%= confession.id %>')" class="flex items-center gap-1.5 text-xs font-bold text-indigo-600 hover:bg-indigo-50 px-3 py-1.5 rounded-full transition-colors">
                <span class="material-symbols-outlined text-[18px]">share</span> Bagikan
            </button>
        </div>
    </div>

    <div class="social-card p-6">
        <h3 class="text-sm font-extrabold text-slate-900 flex items-center gap-2 mb-6">
            <span class="material-symbols-outlined text-[20px]">forum</span> 
            Tanggapan (<span id="totalKomen"><%= confession.komentar ? confession.komentar.length : 0 %></span>)
        </h3>

        <div id="formKomenContainer" class="mb-8">
            <div class="space-y-3">
                <input type="text" id="pengirimKomen" placeholder="Nama (opsional)" class="w-full bg-slate-100 border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 outline-none font-medium">
                <textarea id="inputKomen" rows="2" placeholder="Tuliskan tanggapanmu..." class="w-full bg-slate-100 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none font-medium resize-none"></textarea>
                <div class="flex justify-end">
                    <button onclick="kirimKomen('<%= confession.id %>')" id="btnKomen" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-full font-bold text-sm transition-all shadow-sm">Kirim</button>
                </div>
            </div>
            <p class="text-[10px] text-slate-400 mt-3">*Batas 1 tanggapan per postingan.</p>
        </div>

        <div id="listKomentar" class="space-y-4">
            <% if (confession.komentar && confession.komentar.length > 0) { %>
                <% confession.komentar.forEach(function(komen) { %>
                    <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-bold text-indigo-600"><%= komen.pengirim || 'Anonim' %></span>
                            <span class="text-[10px] font-bold text-slate-400 uppercase"><%= komen.waktu %></span>
                        </div>
                        <p class="text-[14px] font-medium text-slate-700 leading-relaxed"><%= komen.teks %></p>
                    </div>
                <% }); %>
            <% } else { %>
                <div id="teksKosong" class="text-center py-6">
                    <span class="material-symbols-outlined text-slate-200 text-[48px] mb-2">chat_bubble_outline</span>
                    <p class="text-sm text-slate-400 font-medium">Belum ada tanggapan.</p>
                </div>
            <% } %>
        </div>
    </div>
</main>

<footer class="w-full text-center py-8 text-slate-400">
    <p class="text-[11px] font-bold tracking-widest uppercase">Copyright &copy; 2026 AP. All rights reserved.</p>
</footer>

<script>
document.addEventListener("DOMContentLoaded", () => {
    if (localStorage.getItem('komen_<%= confession.id %>')) sembunyikanFormKomen();
});

function sembunyikanFormKomen() {
    document.getElementById('formKomenContainer').innerHTML = `
        <div class="bg-emerald-50 text-emerald-600 text-xs font-bold text-center p-4 rounded-xl border border-emerald-100 flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[18px] icon-fill">check_circle</span>
            Kamu sudah memberikan tanggapan.
        </div>`;
}

function salinLink(id) { 
    navigator.clipboard.writeText(window.location.origin + '/pengakuan/' + id).then(() => alert('Tautan disalin!')); 
}

async function kirimKomen(id) {
    const inputTeks = document.getElementById('inputKomen');
    const inputNama = document.getElementById('pengirimKomen');
    const btn = document.getElementById('btnKomen');
    const teks = inputTeks.value.trim();
    const nama = inputNama.value.trim();
    
    if(!teks) return;

    btn.disabled = true; btn.innerText = "Mengirim...";

    try {
        const res = await fetch(`/komen/${id}`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isi_komen: teks, pengirim: nama })
        });
        const result = await res.json();
        
        if (result.success) {
            localStorage.setItem('komen_' + id, 'true');
            sembunyikanFormKomen();
            
            if (document.getElementById('teksKosong')) document.getElementById('teksKosong').remove();

            const list = document.getElementById('listKomentar');
            const elemenBaru = document.createElement('div');
            elemenBaru.className = "bg-slate-50 p-4 rounded-2xl border border-slate-100 animate-pulse";
            elemenBaru.innerHTML = `
                <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-bold text-indigo-600">${result.data.pengirim}</span>
                    <span class="text-[10px] font-bold text-slate-400 uppercase">BARU SAJA</span>
                </div>
                <p class="text-[14px] font-medium text-slate-700 leading-relaxed">${result.data.teks}</p>`;
            
            list.prepend(elemenBaru);
            const total = document.getElementById('totalKomen');
            total.innerText = parseInt(total.innerText) + 1;
            
            setTimeout(() => elemenBaru.classList.remove('animate-pulse'), 1000);
        } else {
            if (result.message === 'Sudah berkomentar') {
                alert('Sistem mendeteksi Anda sudah memberikan tanggapan.');
                localStorage.setItem('komen_' + id, 'true');
                sembunyikanFormKomen();
            }
            btn.disabled = false; btn.innerText = "Kirim";
        }
    } catch (err) {
        btn.disabled = false; btn.innerText = "Kirim";
    }
}
</script>
</body>
</html>
