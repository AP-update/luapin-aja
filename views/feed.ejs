<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Jelajah - Luapin Aja</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com"></script>
<style>
    body { font-family: 'Manrope', sans-serif; background: #f0f2f5; }
    .glass-nav { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,0,0,0.05); }
    .social-card { background: #ffffff; border-radius: 12px; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1); border: 1px solid rgba(0,0,0,0.05); }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
    .icon-fill { font-variation-settings: 'FILL' 1; }
    .btn-action { transition: all 0.2s; border-radius: 6px; }
    .btn-action:hover { background: #f2f2f2; }
    .toast-enter { transform: translateY(-150%) translateX(-50%); opacity: 0; }
    .toast-active { transform: translateY(0) translateX(-50%); opacity: 1; }
</style>
</head>
<body class="text-slate-800 flex flex-col min-h-screen" oncontextmenu="return false;">

<% if (success) { %>
    <div id="toast" class="toast-enter fixed top-6 left-1/2 z-50 bg-white border border-emerald-100 text-emerald-800 px-6 py-4 rounded-2xl flex items-center gap-4 shadow-2xl transition-all duration-700 ease-out">
        <div class="bg-emerald-100 p-2 rounded-full flex"><span class="material-symbols-outlined icon-fill text-emerald-600">verified</span></div>
        <div>
            <h4 class="font-bold text-sm">Suara Terkirim</h4>
            <p class="text-xs font-medium opacity-80">Menunggu tinjauan admin.</p>
        </div>
    </div>
    <script>
        setTimeout(() => document.getElementById('toast').classList.replace('toast-enter', 'toast-active'), 100);
        setTimeout(() => document.getElementById('toast').classList.replace('toast-active', 'toast-enter'), 4000);
    </script>
<% } %>

<nav class="fixed top-0 w-full z-40 glass-nav">
    <div class="max-w-[680px] mx-auto flex justify-between items-center h-14 px-4">
        <a href="/" class="flex items-center gap-2 group">
            <span class="material-symbols-outlined text-indigo-600 icon-fill text-[28px]">psychology_alt</span>
            <span class="text-lg font-bold tracking-tighter">Luapin Aja</span>
        </a>
        <a href="/tulis" class="p-2 bg-indigo-50 text-indigo-600 rounded-full hover:bg-indigo-100 transition-colors">
            <span class="material-symbols-outlined">add</span>
        </a>
    </div>
</nav>

<main class="max-w-[680px] w-full mx-auto px-4 pt-20 pb-20 flex-grow">
    <div class="social-card p-4 mb-6 flex items-center gap-3">
        <div class="w-10 h-10 bg-gradient-to-tr from-slate-200 to-slate-100 rounded-full flex items-center justify-center text-slate-400">
            <span class="material-symbols-outlined">person</span>
        </div>
        <a href="/tulis" class="flex-grow bg-slate-100 hover:bg-slate-200 py-2 px-4 rounded-full text-slate-500 text-sm transition-colors text-left">
            Apa yang kamu pikirkan? Luapin aja...
        </a>
    </div>

    <div class="space-y-4">
        <% if (confessions.length === 0) { %>
            <div class="text-center py-12"><p class="text-slate-500 text-lg">Belum ada suara yang terdengar.</p></div>
        <% } else { %>
            <% confessions.forEach(function(confession) { %>
                <div class="social-card">
                    <div class="p-4 flex items-center gap-3">
                        <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center font-bold text-sm">
                            <%= (confession.pengirim || 'A').charAt(0).toUpperCase() %>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-slate-900"><%= confession.pengirim || 'Anonim' %></h3>
                            <p class="text-[11px] text-slate-500 font-medium"><%= confession.waktuFormat %></p>
                        </div>
                    </div>

                    <div class="px-4 pb-4">
                        <% if (confession.category && confession.category !== 'Tanpa Kategori') { %>
                            <span class="text-[11px] font-bold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-md mb-2 inline-block">
                                #<%= confession.category %>
                            </span>
                        <% } %>
                        <p class="text-[15px] text-slate-800 leading-relaxed"><%= confession.message %></p>
                    </div>

                    <div class="px-4 py-2 flex items-center justify-between border-t border-slate-50">
                        <div class="flex items-center gap-1">
                            <div class="flex -space-x-1">
                                <div class="bg-rose-500 text-white rounded-full p-0.5 border-2 border-white flex"><span class="material-symbols-outlined text-[10px] icon-fill">favorite</span></div>
                            </div>
                            <span class="text-xs text-slate-500 font-medium hug-count-text-<%= confession.id %>"><%= confession.hugs || 0 %> Dukungan</span>
                        </div>
                        <div class="text-xs text-slate-500 font-medium">
                            <%= confession.komentar ? confession.komentar.length : 0 %> Komentar
                        </div>
                    </div>

                    <div class="px-2 py-1 flex items-center border-t border-slate-50">
                        <button onclick="kirimDukungan('<%= confession.id %>', this)" data-id="<%= confession.id %>" class="btn-dukungan flex-grow flex items-center justify-center gap-2 py-2 text-sm font-bold text-slate-600 btn-action group">
                            <span class="material-symbols-outlined text-[20px] group-active:scale-125 transition-transform">favorite</span>
                            <span>Dukung</span>
                        </button>
                        
                        <a href="/pengakuan/<%= confession.id %>" class="flex-grow flex items-center justify-center gap-2 py-2 text-sm font-bold text-slate-600 btn-action">
                            <span class="material-symbols-outlined text-[20px]">chat_bubble</span> 
                            <span>Tanggapi</span>
                        </a>

                        <button onclick="salinLink('<%= confession.id %>')" class="flex-grow flex items-center justify-center gap-2 py-2 text-sm font-bold text-slate-600 btn-action">
                            <span class="material-symbols-outlined text-[20px]">share</span> 
                            <span>Bagikan</span>
                        </button>
                    </div>
                </div>
            <% }); %>
        <% } %>
    </div>
</main>

<footer class="w-full text-center py-8 text-slate-400">
    <p class="text-[11px] font-bold tracking-widest uppercase">Copyright &copy; 2026 AP. All rights reserved.</p>
</footer>

<script>
document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll('.btn-dukungan').forEach(btn => {
        if (localStorage.getItem('dukungan_' + btn.dataset.id)) {
            formatButtonActive(btn);
        }
    });
});

function formatButtonActive(btn) {
    btn.classList.add('text-rose-500');
    btn.classList.remove('text-slate-600');
    btn.querySelector('.material-symbols-outlined').classList.add('icon-fill');
    btn.disabled = true;
}

async function kirimDukungan(id, btn) {
    if (btn.disabled) return;
    btn.disabled = true;
    try {
        const res = await fetch(`/dukungan/${id}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            const countLabel = document.querySelector('.hug-count-text-' + id);
            let current = parseInt(countLabel.innerText);
            countLabel.innerText = (current + 1) + ' Dukungan';
            formatButtonActive(btn);
            localStorage.setItem('dukungan_' + id, 'true');
        } else if (data.message === 'Sudah mendukung') {
            formatButtonActive(btn);
            localStorage.setItem('dukungan_' + id, 'true');
        } else {
            btn.disabled = false;
        }
    } catch (err) {
        btn.disabled = false;
    }
}

function salinLink(id) { 
    const fullUrl = window.location.origin + '/pengakuan/' + id;
    navigator.clipboard.writeText(fullUrl).then(() => {
        alert('Tautan disalin!');
    });
}
</script>
</body>
</html>
