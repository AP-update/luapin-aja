<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Admin - Luapin Aja</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&display=swap" rel="stylesheet"/>
<style>
    body { font-family: 'Manrope', sans-serif; background: #f8f9fa; }
    .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 10px 40px -10px rgba(99, 102, 241, 0.1);
    }
</style>
</head>
<body class="flex flex-col min-h-screen">
    <main class="flex-grow flex items-center justify-center p-6">
        <div class="glass-panel max-w-md w-full p-8 rounded-2xl text-center">
            <h1 class="text-2xl font-bold text-indigo-600 mb-2">Ruang Rahasia</h1>
            <p class="text-slate-500 text-sm mb-8">Hanya untuk kurator Luapin Aja.</p>
    
            <% if (error) { %>
                <div class="bg-red-50 text-red-600 text-sm p-3 rounded-lg mb-6 border border-red-100">
                    Sandi salah. Coba lagi.
                </div>
            <% } %>
    
            <form action="/ruang-admin" method="POST" class="space-y-4">
                <input type="password" name="password" placeholder="Masukkan Sandi Akses" required
                    class="w-full bg-white/50 border border-slate-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition-all">
                <button type="submit" 
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-xl transition-all shadow-lg shadow-indigo-200">
                    Masuk
                </button>
            </form>
            <a href="/" class="block mt-6 text-sm text-indigo-500 hover:underline">Kembali ke Beranda</a>
        </div>
    </main>

    <footer class="w-full text-center py-6 mt-auto">
        <p class="text-sm font-bold text-slate-400 tracking-wide">Copyright &copy; 2026 AP. All rights reserved.</p>
    </footer>
</body>
</html>
